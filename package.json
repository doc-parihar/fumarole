{
  "name": "fumarole",
  "version": "1.0.0",
  "description": "Embed a fully interactive terminal inside Obsidian. Designed for any shell.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "terminal", "gemini", "cli", "xterm", "pty"],
  "author": "Koshtubh Singh Parihar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/doc-parihar/fumarole"
  },
  "devDependencies": {
    "@types/node": "^16.11.6",
    "builtin-modules": "^5.0.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "typescript": "4.9.5"
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "tslib": "^2.8.1",
    "ws": "^8.19.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}
